<?xml version="1.0" encoding="utf-8"?>
<!-- URDF from server_rack_v2.xml — HTML comments in MJCF are not parsed, so only uncommented elements appear. -->
<!-- Same-dir mesh: MTL+map_Kd; mesh visual also includes fallback color. -->
<!-- For Isaac Sim USD, prefer: python -m mujoco_usd_converter (MJCF path) (output directory). -->
<!-- Re-embed URDF colors+textures on mesh: pass flag force-urdf-mesh-materials on the CLI. -->

<robot name="network_rack">
  <link name="world"/>

  <!-- MJCF /asset: named materials (matches Material nodes when texture is 2D file) -->
  <material name="cable_yellow">
    <color rgba="1.0 0.9 0.0 1.0"/>
  </material>
  <material name="glass_door">
    <color rgba="0.1 0.5 0.8 0.2"/>
  </material>
  <material name="led_green">
    <color rgba="0.15 1.0 0.25 1.0"/>
  </material>
  <material name="led_red">
    <color rgba="0.95 0.12 0.12 1.0"/>
  </material>
  <material name="rack_metal">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="switch_face">
    <color rgba="0.8 0.8 0.8 1.0"/>
  </material>

  <link name="scene_link">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="0.5"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <link name="cabinet_link">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="0.5"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual name="cabinet_v0">
      <origin xyz="0 0.3 0.9" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.8 0.04 1.8"/>
      </geometry>
      <material name="rack_metal"/>
    </visual>
    <collision>
      <origin xyz="0 0.3 0.9" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.8 0.04 1.8"/>
      </geometry>
    </collision>
    <visual name="cabinet_v1">
      <origin xyz="0 -0.3 0.9" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.8 0.04 1.8"/>
      </geometry>
