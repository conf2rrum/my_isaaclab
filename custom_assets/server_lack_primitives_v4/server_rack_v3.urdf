      <geometry>
        <box size="0.8 0.04 1.8"/>
      </geometry>
    </collision>
    <visual name="cabinet_v2">
      <origin xyz="0 0 1.8" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.8 0.6 0.04"/>
      </geometry>
      <material name="rack_metal"/>
    </visual>
    <collision>
      <origin xyz="0 0 1.8" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.8 0.6 0.04"/>
      </geometry>
    </collision>
  </link>

  <link name="glass_door_link">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="0.5"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
